{
  "schemaId": "agent.semantic-protocols.semantic-tree-sitter-grammar-profile",
  "schemaVersion": "1",
  "grammarId": "tree-sitter-typescript",
  "grammarProfileVersion": "2026-06-05.v1",
  "dialect": "tree-sitter-query",
  "upstream": {
    "repository": "https://github.com/tree-sitter/tree-sitter-typescript",
    "revision": "75b3874edb2dc714fb1fd77a32013d0f8699989f",
    "version": "HEAD-2026-06-05"
  },
  "aspWorkspace": {
    "owner": "main-asp",
    "repository": "https://github.com/tao3k/agent-semantic-protocols",
    "revision": "555b35b247325788940d2ac5f6c03eada47ab658",
    "queryCorpusValidator": "tools/validate-tree-sitter-typescript-query-corpus.py"
  },
  "sourceAuthority": "native-parser-adapter",
  "adapterModes": ["native-projection", "cached-replay"],
  "compatibilityLevels": ["exact", "approximate", "native-only"],
  "catalogs": [
    {
      "id": "declarations",
      "path": "tree-sitter/tree-sitter-typescript/queries/declarations.scm",
      "captures": [
        "function.definition",
        "function.name",
        "class.definition",
        "class.name",
        "interface.definition",
        "interface.name",
        "type.definition",
        "type.name",
        "enum.definition",
        "enum.name",
        "variable.definition",
        "variable.name",
        "import.declaration",
        "import.source",
        "export.declaration"
      ]
    },
    {
      "id": "imports",
      "path": "tree-sitter/tree-sitter-typescript/queries/imports.scm",
      "captures": ["import.declaration", "import.source", "export.declaration", "export.source"]
    },
    {
      "id": "calls",
      "path": "tree-sitter/tree-sitter-typescript/queries/calls.scm",
      "captures": ["call.expression", "call.target"]
    }
  ],
  "nativeFactProjection": [
    {
      "semanticFact": "declaration.function",
      "nativeFacts": ["TypeScript.FunctionDeclaration"],
      "catalogId": "declarations",
      "captures": ["function.definition", "function.name"],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "declaration.type",
      "nativeFacts": [
        "TypeScript.ClassDeclaration",
        "TypeScript.InterfaceDeclaration",
        "TypeScript.TypeAliasDeclaration",
        "TypeScript.EnumDeclaration"
      ],
      "catalogId": "declarations",
      "captures": [
        "class.definition",
        "class.name",
        "interface.definition",
        "interface.name",
        "type.definition",
        "type.name",
        "enum.definition",
        "enum.name"
      ],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "declaration.import",
      "nativeFacts": ["TypeScript.ImportDeclaration", "TypeScript.ExportDeclaration"],
      "catalogId": "imports",
      "captures": ["import.declaration", "import.source", "export.declaration", "export.source"],
      "projectionMode": "native-to-tree-sitter-captures"
    },
    {
      "semanticFact": "expression.call",
      "nativeFacts": ["TypeScript.CallExpression"],
      "catalogId": "calls",
      "captures": ["call.expression", "call.target"],
      "projectionMode": "native-to-tree-sitter-captures"
    }
  ],
  "queryCorpus": {
    "path": "tree-sitter/tree-sitter-typescript/test/corpus",
    "validator": "tools/validate-tree-sitter-typescript-query-corpus.py"
  },
  "corpusProfilePath": "tree-sitter/tree-sitter-typescript/corpus-profile.json"
}
