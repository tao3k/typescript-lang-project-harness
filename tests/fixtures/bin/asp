#!/usr/bin/env node

import { stdin, stderr } from "node:process";

const args = process.argv.slice(2);
if (
  args[0] !== "graph" ||
  args[1] !== "render" ||
  !args.includes("--packet") ||
  !args.includes("-") ||
  !args.includes("--view") ||
  !args.includes("seeds")
) {
  stderr.write("test asp fixture only supports graph render --packet - --view seeds\n");
  process.exit(2);
}

const input = await readStdin();
const packet = JSON.parse(input);
const fields = packet.header?.fields ?? {};
const synthesis = packet.searchSynthesis ?? {};
const seeds = collectSeeds(packet);
const aliases = assignAliases(seeds);
const query = fields.q ?? packet.query ?? firstQuerySetValue(packet);
const headerFields = {
  ...fields,
};
const algorithm = synthesis.algorithm ?? fields.alg ?? "native-syntax-query";
delete headerFields.q;
delete headerFields.alg;
const leadingHeaderFields =
  packet.header?.kind === "search-policy"
    ? {
        ...(query === undefined ? {} : { q: query }),
        alg: algorithm,
        ...headerFields,
      }
    : {
        ...(query === undefined ? {} : { q: query }),
        ...headerFields,
        alg: algorithm,
      };

const lines = [
  `[${packet.header?.kind ?? packet.method ?? "search"}] ${formatFields(leadingHeaderFields)}`
    .replace(/\s+/gu, " ")
    .trimEnd(),
  "legend: aliases ID:kind; node ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
  `aliases=G:search${aliases.length > 0 ? `,${aliases.map((alias) => `${alias.id}:${alias.kind}`).join(",")}` : ""}`,
];

if (aliases.length > 0) {
  lines.push(aliases.map((alias) => alias.rendered).join(";"));
  lines.push(`G>{${aliases.map((alias) => `${alias.id}:${alias.edge}`).join(",")}}`);
  lines.push(
    `rank=${aliases.map((alias) => alias.id).join(",")} frontier=${aliases
      .map((alias) => `${alias.id}.${alias.next}`)
      .join(",")}`,
  );
}

lines.push(
  "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)",
);

process.stdout.write(`${lines.join("\n")}\n`);

async function readStdin() {
  let input = "";
  stdin.setEncoding("utf8");
  for await (const chunk of stdin) {
    input += chunk;
  }
  return input;
}

function collectSeeds(packet) {
  const querySeeds = [];
  const ownerSeeds = [];
  const testSeeds = [];
  const symbolSeeds = [];
  const otherSeeds = [];

  const query = packet.query ?? firstQuerySetValue(packet);
  if (packet.header?.kind === "search-fzf" && query !== undefined) {
    querySeeds.push({ kind: "fzf", target: query });
  }

  for (const action of packet.nextActions ?? []) {
    addSeed(action, ownerSeeds, testSeeds, symbolSeeds, otherSeeds);
  }
  for (const resolution of packet.ownerResolution ?? []) {
    if (resolution.ownerPath !== undefined) {
      ownerSeeds.push({ kind: "owner", target: resolution.ownerPath });
    }
  }
  for (const windowTarget of packet.searchSynthesis?.windowSet ?? []) {
    if (windowTarget.target !== undefined) {
      ownerSeeds.push({ kind: "owner", target: windowTarget.target });
    }
  }
  for (const path of [
    ...(packet.searchSynthesis?.highImpactOwners ?? []),
    ...(packet.searchSynthesis?.editFrontier ?? []),
    ...(packet.searchSynthesis?.frontierOwners ?? []),
  ]) {
    ownerSeeds.push({ kind: "owner", target: path });
  }

  const synthesisTests = [];
  const synthesisSymbols = [];
  const synthesisOthers = [];
  for (const seed of packet.searchSynthesis?.seeds ?? []) {
    if (seed.kind === "owner") {
      ownerSeeds.push(seed);
    } else if (seed.kind === "tests" || seed.kind === "test") {
      synthesisTests.push(seed);
    } else if (seed.kind === "symbol") {
      synthesisSymbols.push(seed);
    } else if (seed.kind === "fzf" || seed.kind === "query") {
      querySeeds.push(seed);
    } else {
      synthesisOthers.push(seed);
    }
  }
  for (const owner of packet.owners ?? []) {
    if (owner.path !== undefined) {
      ownerSeeds.push({ kind: "owner", target: owner.path });
    }
  }
  for (const handle of packet.semanticHandles ?? []) {
    if (handle.ownerPath !== undefined) {
      ownerSeeds.push({ kind: "owner", target: handle.ownerPath });
    }
    for (const testPath of handle.testPaths ?? []) {
      testSeeds.push({ kind: "tests", target: testPath });
    }
  }
  const scopedHookRoots = Array.isArray(packet.queryComposition?.scope?.roots);
  if (synthesisTests.length === 0 || !scopedHookRoots) {
    for (const path of packet.searchSynthesis?.testFrontier ?? []) {
      testSeeds.push({ kind: "tests", target: path });
    }
  }

  return [
    ...dedupeSeeds(querySeeds),
    ...dedupeSeeds(ownerSeeds),
    ...dedupeSeeds(testSeeds),
    ...dedupeSeeds(interleaveTestsAndSymbols(synthesisTests, synthesisSymbols)),
    ...dedupeSeeds(symbolSeeds),
    ...dedupeSeeds(otherSeeds),
    ...dedupeSeeds(synthesisOthers),
  ];
}

function addSeed(seed, ownerSeeds, testSeeds, symbolSeeds, otherSeeds) {
  if (seed?.target === undefined || seed?.kind === undefined) {
    return;
  }
  if (seed.kind === "owner") {
    ownerSeeds.push(seed);
  } else if (seed.kind === "tests" || seed.kind === "test") {
    testSeeds.push(seed);
  } else if (seed.kind === "symbol") {
    symbolSeeds.push(seed);
  } else {
    otherSeeds.push(seed);
  }
}

function interleaveTestsAndSymbols(testSeeds, symbolSeeds) {
  const maxLength = Math.max(testSeeds.length, symbolSeeds.length);
  const result = [];
  for (let index = 0; index < maxLength; index += 1) {
    if (testSeeds[index] !== undefined) {
      result.push(testSeeds[index]);
    }
    if (symbolSeeds[index] !== undefined) {
      result.push(symbolSeeds[index]);
    }
  }
  return result;
}

function dedupeSeeds(seeds) {
  const seen = new Set();
  const result = [];
  for (const seed of seeds) {
    if (seed?.target === undefined || seed?.kind === undefined) {
      continue;
    }
    const key = `${seed.kind}\0${seed.target}`;
    if (seen.has(key)) {
      continue;
    }
    seen.add(key);
    result.push(seed);
  }
  return result;
}

function assignAliases(seeds) {
  const counts = new Map();
  return seeds.map((seed) => {
    const descriptor = describeSeed(seed);
    const count = counts.get(descriptor.prefix) ?? 0;
    counts.set(descriptor.prefix, count + 1);
    const id = count === 0 ? descriptor.prefix : `${descriptor.prefix}${count + 1}`;
    return {
      id,
      kind: descriptor.kind,
      next: descriptor.next,
      edge: descriptor.edge,
      rendered: `${id}=${descriptor.kind}:${descriptor.role}(${escapeRoleValue(seed.target)})!${descriptor.next}`,
    };
  });
}

function describeSeed(seed) {
  switch (seed.kind) {
    case "fzf":
    case "query":
      return { prefix: "Q", kind: "query", role: "term", next: "fzf", edge: "matches" };
    case "owner":
    case "ingest":
      return { prefix: "O", kind: "owner", role: "path", next: "owner", edge: "selects" };
    case "tests":
    case "test":
      return { prefix: "T", kind: "test", role: "path", next: "tests", edge: "tests" };
    case "symbol":
      return { prefix: "S", kind: "symbol", role: "symbol", next: "symbol", edge: "selects" };
    case "dependency":
    case "deps":
      return { prefix: "D", kind: "dependency", role: "dep", next: "dependency", edge: "selects" };
    case "finding":
      return { prefix: "F", kind: "finding", role: "rule", next: "owner", edge: "selects" };
    default:
      return {
        prefix: "N",
        kind: seed.kind,
        role: "target",
        next: seed.kind,
        edge: "selects",
      };
  }
}

function firstQuerySetValue(packet) {
  return packet.querySet?.[0]?.value;
}

function formatFields(fields) {
  return Object.entries(fields)
    .filter(([, value]) => value !== undefined)
    .map(([key, value]) => `${key}=${formatValue(value)}`)
    .join(" ");
}

function formatValue(value) {
  if (Array.isArray(value)) {
    return value.map((entry) => String(entry)).join(",");
  }
  return String(value);
}

function escapeRoleValue(value) {
  return String(value).replaceAll(")", "\\)");
}
