{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-ast-patch-receipt.v1.schema.json",
  "title": "Semantic AST Patch Receipt",
  "description": "Verification, dry-run, or apply receipt emitted for a semantic AST patch request. Codex verifier receipts remain non-mutating; trusted provider-native apply receipts may record local mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "status",
    "mode",
    "capability",
    "mutationAvailable",
    "target",
    "verification",
    "failureKind",
    "failures",
    "supportedOperations",
    "next"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-ast-patch-receipt"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.ast-patch"
    },
    "protocolVersion": {
      "const": "1"
    },
    "status": {
      "enum": [
        "verified",
        "applied",
        "failed"
      ]
    },
    "mode": {
      "enum": [
        "verify",
        "dry-run",
        "apply"
      ]
    },
    "capability": {
      "enum": [
        "codex-compact-safety-verifier",
        "provider-ast-dry-run",
        "provider-ast-apply"
      ]
    },
    "mutationAvailable": {
      "type": "boolean"
    },
    "languageId": {
      "$ref": "#/$defs/identifier"
    },
    "target": {
      "$ref": "#/$defs/receiptTarget"
    },
    "operation": {
      "oneOf": [
        {
          "$ref": "#/$defs/operationName"
        },
        {
          "type": "null"
        }
      ]
    },
    "supportedOperations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operationName"
      },
      "uniqueItems": true
    },
    "mechanicalEditPlan": {
      "oneOf": [
        {
          "$ref": "#/$defs/mechanicalEditPlan"
        },
        {
          "type": "null"
        }
      ]
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failureKind": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "invalid-packet",
        "unsupported-operation",
        "target-read-invalid",
        "snippet-missing",
        "snippet-parse-error",
        "project-root-invalid",
        "target-outside-project",
        "source-read-error",
        "target-range-invalid",
        "target-preimage-mismatch",
        "target-item-parse-error",
        "target-item-mismatch",
        "file-reparse-failed",
        "source-write-error",
        "formatter-failed",
        "formatter-output-reparse-failed",
        null
      ]
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next": {
      "type": "string",
      "description": "Command-shaped next guidance. Receipts should name the ast-patch template command, provider dry-run/apply command, exact-read preimage command, Codex apply_patch boundary when required, or policy check as appropriate.",
      "minLength": 1
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "capability": {
            "const": "codex-compact-safety-verifier"
          }
        },
        "required": ["capability"]
      },
      "then": {
        "properties": {
          "mutationAvailable": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capability": {
            "const": "provider-ast-dry-run"
          }
        },
        "required": ["capability"]
      },
      "then": {
        "properties": {
          "mode": {
            "const": "dry-run"
          },
          "status": {
            "enum": ["verified", "failed"]
          },
          "mutationAvailable": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capability": {
            "const": "provider-ast-apply"
          }
        },
        "required": ["capability"]
      },
      "then": {
        "properties": {
          "mode": {
            "const": "apply"
          },
          "status": {
            "enum": ["applied", "failed"]
          }
        }
      }
    }
  ],
  "$defs": {
    "operationName": {
      "type": "string",
      "enum": [
        "append_to_block",
        "insert_before_statement",
        "insert_after_statement",
        "replace_statement",
        "replace_expression",
        "replace_call_arg",
        "insert_import",
        "remove_import",
        "remove_statement",
        "remove_item",
        "replace_item"
      ]
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "sourceLocator": {
      "type": "string",
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
    },
    "receiptTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ownerPath": {
          "oneOf": [
            {
              "$ref": "#/$defs/projectPath"
            },
            {
              "type": "null"
            }
          ]
        },
        "locator": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "read": {
          "oneOf": [
            {
              "$ref": "#/$defs/sourceLocator"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "mechanicalEditPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "operation",
        "targetRead",
        "estimatedEdits",
        "maxEdits",
        "safeForLargeChange",
        "mutationAvailable",
        "requiresCodexApplyPatch"
      ],
      "properties": {
        "kind": {
          "enum": [
            "codex-dry-run",
            "provider-dry-run",
            "provider-apply"
          ]
        },
        "operation": {
          "$ref": "#/$defs/operationName"
        },
        "targetRead": {
          "$ref": "#/$defs/sourceLocator"
        },
        "estimatedEdits": {
          "type": "integer",
          "minimum": 1
        },
        "maxEdits": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "safeForLargeChange": {
          "type": "boolean"
        },
        "mutationAvailable": {
          "type": "boolean"
        },
        "requiresCodexApplyPatch": {
          "type": "boolean"
        },
        "changedRanges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceLocator"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scalar": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    }
  }
}
