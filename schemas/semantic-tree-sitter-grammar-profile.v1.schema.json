{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-tree-sitter-grammar-profile.v1.schema.json",
  "title": "Semantic Tree-sitter Grammar Profile",
  "description": "Shared ASP-owned profile for tree-sitter-compatible query catalogs, upstream grammar provenance, provider-local query corpus fixtures, and ASP validator provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "grammarId",
    "grammarProfileVersion",
    "dialect",
    "upstream",
    "aspWorkspace",
    "queryCorpus",
    "nativeFactProjection",
    "sourceAuthority",
    "adapterModes",
    "compatibilityLevels",
    "catalogs"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-tree-sitter-grammar-profile"
    },
    "schemaVersion": {
      "const": "1"
    },
    "grammarId": {
      "type": "string",
      "pattern": "^tree-sitter-[a-z][a-z0-9_-]*$"
    },
    "grammarProfileVersion": {
      "type": "string",
      "minLength": 1
    },
    "dialect": {
      "const": "tree-sitter-query"
    },
    "upstream": {
      "$ref": "#/$defs/upstream"
    },
    "aspWorkspace": {
      "$ref": "#/$defs/aspWorkspace"
    },
    "standardQueries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/referenceQuery"
      }
    },
    "corpusProfilePath": {
      "$ref": "#/$defs/projectPath"
    },
    "queryCorpus": {
      "$ref": "#/$defs/queryCorpus"
    },
    "nativeFactProjection": {
      "type": "array",
      "description": "Provider-owned native parser/compiler facts projected into tree-sitter-compatible captures. This keeps native authority visible through the canonical .scm ABI instead of hidden provider-private fields.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nativeFactProjection"
      }
    },
    "sourceAuthority": {
      "enum": [
        "native-parser",
        "native-parser-adapter",
        "tree-sitter-runtime",
        "hybrid",
        "cached-provider-export"
      ]
    },
    "adapterModes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "native-projection",
          "hybrid",
          "tree-sitter-runtime",
          "cached-replay"
        ]
      }
    },
    "compatibilityLevels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "exact",
          "approximate",
          "native-only",
          "tree-only"
        ]
      }
    },
    "catalogs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/catalog"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/projectPath"
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "version"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri"
        },
    "revision": {
      "type": "string",
      "description": "Main ASP repository baseline commit used to validate this grammar profile. Validators should require this revision to be reachable from the active ASP checkout, not equal to the active HEAD; the root repository commit that consumes a language profile will naturally advance after the profile is written.",
      "pattern": "^[0-9a-f]{40}$"
    },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "aspWorkspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
      "owner",
      "repository",
      "revision",
      "contractFingerprint",
      "queryCorpusValidator"
      ],
      "properties": {
        "owner": {
          "const": "main-asp"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
    "revision": {
      "type": "string",
      "description": "Main ASP repository commit recorded as provenance for the tree-sitter contract validation run. This is not a current-HEAD equality gate; contract compatibility is enforced by contractFingerprint.",
      "pattern": "^[0-9a-f]{40}$"
    },
    "contractFingerprint": {
      "type": "string",
      "description": "Content fingerprint for the ASP tree-sitter query ABI/schema/validator contract used by this grammar profile. Main-repo commits may advance without profile churn when this fingerprint is unchanged.",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
        "queryCorpusValidator": {
          "$ref": "#/$defs/projectPath"
        }
      }
    },
    "referenceQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "source",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "queryCorpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "validator"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "validator": {
          "$ref": "#/$defs/projectPath"
        },
        "realLibraryCases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projectPath"
          }
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "captures"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "captures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
          }
        }
      }
    },
    "nativeFactProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semanticFact",
        "nativeFacts",
        "catalogId",
        "captures",
        "projectionMode"
      ],
      "properties": {
        "semanticFact": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        },
        "nativeFacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)+$"
          }
        },
        "catalogId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "captures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
          }
        },
        "projectionMode": {
          "enum": [
            "native-to-tree-sitter-captures"
          ]
        }
      }
    }
  }
}
