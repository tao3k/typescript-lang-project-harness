{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-formal-proof-pilot.v1.schema.json",
  "title": "Semantic Formal Proof Pilot",
  "description": "Shared proof-pilot contract for bounded or formal evidence that a harness rule judgment is reliable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "proofId",
    "producer",
    "target",
    "method",
    "status",
    "claims",
    "checks"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-formal-proof-pilot"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.formal-proof-pilot"
    },
    "protocolVersion": {
      "const": "1"
    },
    "proofId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    },
    "producer": {
      "$ref": "#/$defs/producer"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "method": {
      "$ref": "#/$defs/method"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "receiptIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "providerId", "namespace"],
      "properties": {
        "languageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "providerId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "enum": [
            "parser-fact",
            "public-api-shape",
            "module-reasoning-tree",
            "dependency-graph-acyclicity",
            "custom"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ruleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "tool"],
      "properties": {
        "kind": {
          "enum": [
            "exhaustive-small-model",
            "kani",
            "creusot",
            "verus",
            "manual-proof-outline",
            "custom"
          ]
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "status": {
      "enum": ["proved", "proved-bounded", "failed", "skipped", "unknown"]
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimId", "statement", "status"],
      "properties": {
        "claimId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "status", "summary"],
      "properties": {
        "checkId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "modelsChecked": {
          "type": "integer",
          "minimum": 0
        },
        "maxNodes": {
          "type": "integer",
          "minimum": 0
        },
        "counterexample": {
          "$ref": "#/$defs/counterexample"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "counterexample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "scalar": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        }
      ]
    }
  }
}
