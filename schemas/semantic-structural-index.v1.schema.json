{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent.semantic-protocols/schemas/semantic-structural-index.v1.schema.json",
  "title": "Semantic structural index feed",
  "type": "object",
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "generationId",
    "languageId",
    "providerId",
    "exportMethod",
    "projectRoot",
    "rawSourceStored",
    "fileHashes",
    "owners",
    "symbols",
    "dependencyUsages"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-structural-index"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "providerVersion": {
      "type": "string"
    },
    "exportMethod": {
      "const": "index/structural"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageRoot": {
      "type": "string"
    },
    "sourceAuthority": {
      "type": "string"
    },
    "sourceArtifactId": {
      "type": "string",
      "pattern": "^structural-index/[^/]+[.]json$"
    },
    "rawSourceStored": {
      "const": false
    },
    "fileHashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileHash"
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/owner"
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol"
      }
    },
    "dependencyUsages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyUsage"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "fileHash": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "owner": {
      "type": "object",
      "required": ["ownerPath", "ownerKind", "sourceAuthority", "queryKeys"],
      "properties": {
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "ownerKind": {
          "type": "string",
          "minLength": 1
        },
        "sourceAuthority": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      },
      "not": {
        "$ref": "#/$defs/rawSourceFields"
      },
      "additionalProperties": true
    },
    "symbol": {
      "type": "object",
      "required": ["ownerPath", "name", "kind", "queryKeys"],
      "properties": {
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "qualifiedName": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "type": "string"
        },
        "sourceLocator": {
          "type": "string"
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      },
      "not": {
        "$ref": "#/$defs/rawSourceFields"
      },
      "additionalProperties": true
    },
    "dependencyUsage": {
      "type": "object",
      "required": ["ownerPath", "packageName", "source", "queryKeys"],
      "properties": {
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "packageVersion": {
          "type": ["string", "null"]
        },
        "apiName": {
          "type": ["string", "null"]
        },
        "importPath": {
          "type": ["string", "null"]
        },
        "manifestPath": {
          "type": ["string", "null"]
        },
        "lockfileHash": {
          "type": ["string", "null"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "sourceLocator": {
          "type": ["string", "null"]
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      },
      "not": {
        "$ref": "#/$defs/rawSourceFields"
      },
      "additionalProperties": true
    },
    "location": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "lineRange": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "queryKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rawSourceFields": {
      "anyOf": [
        { "required": ["body"] },
        { "required": ["code"] },
        { "required": ["content"] },
        { "required": ["rawSource"] },
        { "required": ["rawSourceText"] },
        { "required": ["snippet"] },
        { "required": ["sourceText"] },
        { "required": ["text"] }
      ]
    }
  }
}
