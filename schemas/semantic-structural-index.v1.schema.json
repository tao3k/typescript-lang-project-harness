{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-structural-index.v1.schema.json",
  "title": "Semantic Structural Index",
  "description": "Language-neutral, parser-owned structural cache index for owner, symbol, file, and dependency recall. This packet stores locators, names, dependency identities, and freshness hashes, never source text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "generationId",
    "languageId",
    "providerId",
    "projectRoot",
    "sourceAuthority",
    "rawSourceStored",
    "fileHashes",
    "owners",
    "symbols",
    "dependencyUsages"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-structural-index"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerVersion": {
      "type": "string",
      "minLength": 1
    },
    "exportMethod": {
      "type": "string",
      "minLength": 1
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageRoot": {
      "type": "string",
      "minLength": 1
    },
    "sourceAuthority": {
      "enum": ["native-parser", "type-checker", "manifest", "provider-index"]
    },
    "sourceArtifactId": {
      "type": "string",
      "minLength": 1
    },
    "indexFingerprint": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+:[a-f0-9]{16,64}$"
    },
    "rawSourceStored": {
      "const": false
    },
    "fileHashes": {
      "description": "Freshness evidence for every source or manifest path that contributed rows. This must be non-empty for replayable rows.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileHash"
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ownerRow"
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbolRow"
      }
    },
    "dependencyUsages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyUsageRow"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/projectPath"
    },
    "location": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/location"
    },
    "sourceLocator": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/sourceLocator"
    },
    "fileHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source": {
          "enum": ["provider", "client-derived", "manifest", "lockfile"]
        }
      }
    },
    "queryKeys": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nativeFactRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ownerRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerPath", "ownerKind", "sourceAuthority", "queryKeys"],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "ownerKind": {
          "enum": ["source", "test", "manifest", "module", "package", "document", "custom"]
        },
        "sourceAuthority": {
          "enum": ["native-parser", "type-checker", "manifest", "provider-index"]
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      }
    },
    "symbolKind": {
      "enum": [
        "module",
        "function",
        "method",
        "class",
        "struct",
        "enum",
        "interface",
        "trait",
        "type",
        "constant",
        "field",
        "test",
        "custom"
      ]
    },
    "symbolRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerPath", "name", "kind", "queryKeys"],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "qualifiedName": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/symbolKind"
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "protected",
            "internal",
            "crate",
            "package",
            "unknown"
          ]
        },
        "sourceLocator": {
          "$ref": "#/$defs/sourceLocator"
        },
        "nativeFactRefs": {
          "$ref": "#/$defs/nativeFactRefs"
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      }
    },
    "dependencyUsageRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerPath", "packageName", "source", "queryKeys"],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "packageVersion": {
          "type": "string",
          "minLength": 1
        },
        "apiName": {
          "type": "string",
          "minLength": 1
        },
        "importPath": {
          "type": "string",
          "minLength": 1
        },
        "manifestPath": {
          "$ref": "#/$defs/projectPath"
        },
        "lockfileHash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "source": {
          "enum": ["manifest", "native-parser", "type-checker", "manifest+native-parser"]
        },
        "sourceLocator": {
          "$ref": "#/$defs/sourceLocator"
        },
        "queryKeys": {
          "$ref": "#/$defs/queryKeys"
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
