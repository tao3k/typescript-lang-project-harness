{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tao3k.github.io/agent-semantic-protocols/schemas/semantic-language-registry.v1.schema.json",
  "title": "Semantic Language Registry v1",
  "description": "Language-server-style provider registry with authoritative hook invocation templates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registryId",
    "registryVersion",
    "protocolId",
    "protocolVersion",
    "languages"
  ],
  "properties": {
    "registryId": {
      "const": "agent.semantic-protocols.semantic-language-registry"
    },
    "registryVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/languageRegistration"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "method": {
      "type": "string",
      "pattern": "^(?:guide|query|(search|query|check|proof|review|verification|evidence|ast-patch|agent)/[a-z][a-z0-9_-]*)$"
    },
    "command": {
      "enum": [
        "guide",
        "search",
        "query",
        "check",
        "proof",
        "review",
        "verification",
        "evidence",
        "ast-patch",
        "agent"
      ]
    },
    "providerExecution": {
      "enum": [
        "external-process",
        "embedded"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commandTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stdinMode": {
          "enum": [
            "none",
            "pipe-candidates",
            "pipe-diff",
            "unknown"
          ]
        }
      }
    },
    "benchmarkInvocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "args",
        "expectsJson",
        "maxElapsedMs"
      ],
      "properties": {
        "args": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stdinTemplate": {
          "type": "string"
        },
        "expectsJson": {
          "type": "boolean"
        },
        "maxElapsedMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "schemaRegistration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaId",
        "schemaVersion",
        "path"
      ],
      "properties": {
        "schemaId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "schemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "languageRegistration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "languageId",
        "providerId",
        "binary",
        "namespace",
        "methods",
        "methodDescriptors",
        "schemas",
        "queryPackDescriptor"
      ],
      "properties": {
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "binary": {
          "$ref": "#/$defs/identifier"
        },
        "execution": {
          "$ref": "#/$defs/providerExecution"
        },
        "providerCommandPrefix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/method"
          }
        },
        "methodDescriptors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/methodDescriptor"
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schemaRegistration"
          }
        },
        "queryPackDescriptor": {
          "$ref": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-query-pack-descriptor.v1.schema.json"
        }
      }
    },
    "methodDescriptor": {
      "type": "object",
      "required": [
        "method",
        "command",
        "supportsJson",
        "supportsCompact",
        "invocation"
      ],
      "properties": {
        "method": {
          "$ref": "#/$defs/method"
        },
        "command": {
          "$ref": "#/$defs/command"
        },
        "invocation": {
          "$ref": "#/$defs/commandTemplate"
        },
        "benchmarkInvocation": {
          "$ref": "#/$defs/benchmarkInvocation"
        },
        "supportsJson": {
          "type": "boolean"
        },
        "supportsCompact": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  }
}
