{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-graph-turbo-request.v1.schema.json",
  "title": "Semantic Graph Turbo Request",
  "description": "Schema-owned algorithm request packet consumed by asp-graph-turbo before it emits a semantic-graph-turbo-result response.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "packetKind",
    "surface",
    "queryTerms",
    "profile",
    "algorithm",
    "seedIds",
    "budget"
  ],
  "anyOf": [
    {
      "required": [
        "graph"
      ]
    },
    {
      "required": [
        "graphs"
      ]
    }
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-graph-turbo-request"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "packetKind": {
      "const": "graph-turbo-request"
    },
    "surface": {
      "description": "ASP search surface that produced this graph-turbo request. This is the cache and receipt boundary for ranking semantics, not an agent-facing graph command.",
      "enum": [
        "search-pipe",
        "search-rg",
        "search-fd",
        "search-fzf",
        "search-ingest",
        "evidence-analyze"
      ]
    },
    "queryTerms": {
      "type": "array",
      "description": "LLM-supplied seed query terms or grouped query-set terms normalized as packet inputs. ASP does not model-expand these terms.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "profile": {
      "enum": [
        "owner-query",
        "query-deps",
        "owner-tests",
        "prime",
        "read-frontier",
        "failure-frontier",
        "field-impact",
        "type-impact",
        "collection-impact",
        "failure-evidence",
        "test-selection",
        "affected",
        "evidence-quality",
        "rust-evidence-quality"
      ]
    },
    "algorithm": {
      "const": "typed-ppr-diverse"
    },
    "surfaces": {
      "type": "array",
      "description": "Requested prompt-facing graph projection classes for the search adapter. This selects fact channels such as owner, items, tests, or deps; it is not a pipeline expression.",
      "items": {
        "enum": [
          "owner",
          "items",
          "tests",
          "deps"
        ]
      },
      "uniqueItems": true
    },
    "source": {
      "description": "Candidate source selection requested by search pipe. This selects candidate acquisition only; it is not an output projection.",
      "enum": [
        "auto",
        "provider",
        "finder",
        "ingest"
      ]
    },
    "candidateSources": {
      "type": "array",
      "items": {
        "enum": [
          "provider",
          "finder",
          "ingest"
        ]
      },
      "uniqueItems": true
    },
    "sourceTrace": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceTraceEntry"
      }
    },
    "seedIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nodeId"
      },
      "uniqueItems": true
    },
    "budget": {
      "type": "integer",
      "minimum": 1
    },
    "kindBudgets": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "windowMerge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxGapLines": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "pathBudget": {
      "type": "integer",
      "minimum": 1
    },
    "pathMaxHops": {
      "type": "integer",
      "minimum": 1
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "readMemory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seenSelectors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "delegationHints": {
      "description": "Optional advisory client-runtime delegation hints derived from the same search frontier. Providers do not schedule subagents; clients may use these hints to run read-only explorer workers and return search-subagent receipts.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/delegationHint"
      },
      "uniqueItems": true
    },
    "actionFrontier": {
      "description": "Typed action facts projected from the search-pipe frontier. These facts are the materializer input for prompt-visible nextCommand text; they must not carry materialized shell strings or argv.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionFrontierEntry"
      },
      "uniqueItems": true
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "languageId": {
          "type": "string",
          "minLength": 1
        },
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "graph": {
      "$ref": "#/$defs/graph"
    },
    "graphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/graph"
      }
    }
  },
  "$defs": {
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "graphId": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceGap"
          }
        }
      }
    },
    "nodeId": {
      "type": "string",
      "minLength": 1
    },
    "sourceTraceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "status"
      ],
      "properties": {
        "source": {
          "enum": [
            "provider",
            "finder",
            "ingest"
          ]
        },
        "status": {
          "enum": [
            "complete",
            "partial",
            "used",
            "skipped",
            "empty"
          ]
        },
        "matched": {
          "type": "integer",
          "minimum": 0
        },
        "missing": {
          "type": "integer",
          "minimum": 0
        },
        "normalized": {
          "type": "integer",
          "minimum": 0
        },
        "fields": {
          "type": "object"
        }
      }
    },
    "delegationHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "decision",
        "runtimeOwner",
        "readOnly",
        "noCode",
        "targetActions",
        "reason",
        "receipt"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "fanout": {
          "const": "parallel"
        },
        "instances": {
          "const": "targetActions"
        },
        "branchPrompt": {
          "const": "reasoning-tree"
        },
        "stateOwner": {
          "const": "parent"
        },
        "fanin": {
          "const": "receipt"
        },
        "iterative": {
          "type": "boolean"
        },
        "decision": {
          "const": "advisory"
        },
        "runtimeOwner": {
          "const": "agent-client"
        },
        "modelClass": {
          "enum": [
            "cheap",
            "standard",
            "strong",
            "inherit",
            "custom"
          ]
        },
        "readOnly": {
          "type": "boolean"
        },
        "noCode": {
          "type": "boolean"
        },
        "targetActions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^A[1-9][0-9]*\\.[a-z][a-z0-9_-]*$"
          }
        },
        "maxCommands": {
          "type": "integer",
          "minimum": 1
        },
        "maxTurns": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "receipt": {
          "$ref": "#/$defs/delegationReceipt"
        }
      }
    },
    "delegationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "requiredFields"
      ],
      "properties": {
        "kind": {
          "const": "search-subagent"
        },
        "requiredFields": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "role",
              "action",
              "evidence",
              "missing",
              "next",
              "risk"
            ]
          }
        }
      }
    },
    "actionFrontierEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "capabilityId",
        "target",
        "targetRole",
        "fields"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^A[1-9][0-9]*$"
        },
        "kind": {
          "enum": [
            "query-code",
            "fd-query",
            "rg-query",
            "owner-items",
            "treesitter-query"
          ]
        },
        "capabilityId": {
          "enum": [
            "query",
            "fd",
            "rg",
            "owner-items",
            "treesitter-query"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "targetRole": {
          "enum": [
            "selector",
            "query",
            "owner",
            "syntax-recipe"
          ]
        },
        "fields": {
          "type": "object",
          "propertyNames": {
            "not": {
              "enum": [
                "command",
                "argv"
              ]
            }
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "boolean"
              },
              {
                "type": "integer"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          }
        }
      }
    },
    "evidenceGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gapId",
        "summary"
      ],
      "properties": {
        "gapId": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "role",
        "value"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "weight": {
          "type": "number"
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": [
            "provider",
            "finder",
            "ingest"
          ]
        },
        "confidence": {
          "enum": [
            "exact",
            "likely",
            "heuristic"
          ]
        },
        "matchText": {
          "type": "string",
          "description": "Provider-owned candidate text used by graph-turbo for query-token node weighting. Compact renderers must not print this as source code."
        },
        "syntaxQuery": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "description": "Optional parser-owned syntax query used to locate the candidate symbol."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "start": {
          "type": "integer",
          "minimum": 1
        },
        "end": {
          "type": "integer",
          "minimum": 1
        },
        "fields": {
          "type": "object"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target",
        "relation"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/nodeId"
        },
        "target": {
          "$ref": "#/$defs/nodeId"
        },
        "relation": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "weight": {
          "type": "number"
        },
        "fields": {
          "type": "object"
        }
      }
    }
  }
}
