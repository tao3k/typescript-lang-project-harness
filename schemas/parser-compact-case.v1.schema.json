{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/parser-compact-case.v1.schema.json",
  "title": "Parser Compact Case",
  "description": "Shared case manifest for parser-owned compact output snapshots. The manifest classifies the case and defines provider commands; real and expected output paths are derived from featureClass/caseId/variantId.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "caseId",
    "variantId",
    "languageId",
    "providerId",
    "featureClass",
    "sourceOrigin",
    "fixtureRoot",
    "rawSourcePath",
    "lineCommand",
    "jsonCommand"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.parser-compact-case"
    },
    "schemaVersion": {
      "const": "1"
    },
    "caseId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "variantId": {
      "description": "Provider variant under the language-neutral compact case, such as rust, typescript, python, or julia.",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "featureClass": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "sourceOrigin": {
      "$ref": "#/$defs/sourceOrigin"
    },
    "fixtureRoot": {
      "$ref": "#/$defs/repoPath"
    },
    "rawSourcePath": {
      "$ref": "#/$defs/relativePath"
    },
    "lineCommand": {
      "$ref": "#/$defs/providerCommand"
    },
    "jsonCommand": {
      "$ref": "#/$defs/providerCommand"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "featureClass": {
            "const": "real-library"
          }
        },
        "required": ["featureClass"]
      },
      "then": {
        "properties": {
          "sourceOrigin": {
            "required": ["kind", "repository", "ref", "sourcePath", "license", "note"],
            "properties": {
              "kind": {
                "const": "real-project"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sourceOrigin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "repository", "sourcePath"],
      "properties": {
        "kind": {
          "enum": ["synthetic", "real-project"]
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "$ref": "#/$defs/relativePath"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerCommand": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s\\\\]+(?:/[^\\s\\\\]+)*$"
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s\\\\]+(?:/[^\\s\\\\]+)*$"
    }
  }
}
