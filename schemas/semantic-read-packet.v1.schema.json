{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-read-packet.v1.schema.json",
  "title": "Semantic Read Packet",
  "description": "Provider-owned parser query packet for bounded exact source windows. This is not a root hook command surface.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "required": [
        "sourceWindows"
      ]
    },
    {
      "required": [
        "readPlan"
      ]
    }
  ],
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "binary",
    "namespace",
    "method",
    "projectRoot",
    "selector",
    "outputMode",
    "truncated"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-read-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "method": {
      "type": "string",
      "pattern": "^query/[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "ownerPath": {
      "$ref": "#/$defs/projectPath"
    },
    "selector": {
      "oneOf": [
        {
          "$ref": "#/$defs/projectPath"
        },
        {
          "$ref": "#/$defs/sourceLocator"
        }
      ]
    },
    "fromHook": {
      "enum": [
        "direct-source-read"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "queryTerms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputMode": {
      "const": "read-packet"
    },
    "sourceWindows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceWindow"
      }
    },
    "readPlan": {
      "$ref": "#/$defs/readPlan"
    },
    "semanticHandles": {
      "type": "array",
      "description": "Stable non-code facts that explain why the provider selected the window.",
      "items": {
        "$ref": "semantic-handle.v1.schema.json#/$defs/semanticHandle"
      }
    },
    "nativeSyntaxFacts": {
      "type": "array",
      "description": "Parser-owned syntax facts used to select or repair the read window.",
      "items": {
        "$ref": "semantic-native-syntax-fact-index.v1.schema.json#/$defs/nativeSyntaxFact"
      }
    },
    "truncated": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "lineRange": {
      "type": "string",
      "description": "Compact source line range as start:end, for example 10:43.",
      "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
    },
    "sourceLocator": {
      "type": "string",
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*(?:(?::|-)[1-9][0-9]*)?$"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "lineRange"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "lineRange": {
          "$ref": "#/$defs/lineRange"
        }
      }
    },
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "text"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        }
      }
    },
    "sourceWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownerPath",
        "lineCount",
        "reason",
        "truncated"
      ],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "itemName": {
          "type": "string",
          "minLength": 1
        },
        "itemKind": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "read": {
          "$ref": "#/$defs/sourceLocator"
        },
        "lineCount": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "enum": [
            "direct-selector",
            "owner-item",
            "query-match",
            "search-synthesis-window",
            "fallback-owner-context"
          ]
        },
        "text": {
          "type": "string",
          "description": "Provider-rendered compact source window selected from parser-owned context."
        },
        "lines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/line"
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      }
    },
    "readPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "code",
        "reason",
        "ranges",
        "symbols"
      ],
      "properties": {
        "mode": {
          "enum": [
            "range-outline",
            "search-repair"
          ]
        },
        "code": {
          "const": false
        },
        "reason": {
          "enum": [
            "wide-selector",
            "low-signal-window",
            "broad-selector",
            "missing-query-terms",
            "low-confidence-selector"
          ]
        },
        "ranges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/readPlanRange"
          }
        },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/readPlanSymbol"
          }
        },
        "nextActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/readPlanNextAction"
          }
        }
      }
    },
    "readPlanRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "requested",
        "matched",
        "coverage",
        "density"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "requested": {
          "$ref": "#/$defs/lineRange"
        },
        "selected": {
          "$ref": "#/$defs/lineRange"
        },
        "matched": {
          "$ref": "#/$defs/lineRange"
        },
        "coverage": {
          "enum": [
            "full",
            "head-only",
            "tail-only",
            "middle"
          ]
        },
        "density": {
          "enum": [
            "low",
            "normal",
            "mixed",
            "unknown"
          ]
        }
      }
    },
    "readPlanSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "itemName",
        "itemKind",
        "lineRange",
        "read"
      ],
      "properties": {
        "itemName": {
          "type": "string",
          "minLength": 1
        },
        "itemKind": {
          "type": "string",
          "minLength": 1
        },
        "lineRange": {
          "$ref": "#/$defs/lineRange"
        },
        "read": {
          "$ref": "#/$defs/sourceLocator"
        }
      }
    },
    "readPlanNextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "argv"
      ],
      "properties": {
        "kind": {
          "enum": [
            "query",
            "search"
          ]
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
