{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-read-packet.v1.schema.json",
  "title": "Semantic Read Packet",
  "description": "Provider-owned parser query packet for bounded exact source windows. This is not a root hook command surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "binary",
    "namespace",
    "method",
    "projectRoot",
    "selector",
    "outputMode",
    "sourceWindows",
    "truncated"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-read-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "method": {
      "type": "string",
      "pattern": "^query/[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "ownerPath": {
      "$ref": "#/$defs/projectPath"
    },
    "selector": {
      "$ref": "#/$defs/projectPath"
    },
    "fromHook": {
      "enum": ["direct-source-read"]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "queryTerms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputMode": {
      "const": "read-packet"
    },
    "sourceWindows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceWindow"
      }
    },
    "semanticHandles": {
      "type": "array",
      "description": "Stable non-code facts that explain why the provider selected the window.",
      "items": {
        "$ref": "semantic-handle.v1.schema.json#/$defs/semanticHandle"
      }
    },
    "nativeSyntaxFacts": {
      "type": "array",
      "description": "Parser-owned syntax facts used to select or repair the read window.",
      "items": {
        "$ref": "semantic-native-syntax-fact-index.v1.schema.json#/$defs/nativeSyntaxFact"
      }
    },
    "truncated": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "endLine"],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "endColumn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "text"],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        }
      }
    },
    "sourceWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownerPath",
        "startLine",
        "endLine",
        "lineCount",
        "reason",
        "truncated"
      ],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "itemName": {
          "type": "string",
          "minLength": 1
        },
        "itemKind": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*-[1-9][0-9]*$"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "lineCount": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "enum": [
            "direct-selector",
            "owner-item",
            "query-match",
            "search-synthesis-window",
            "fallback-owner-context"
          ]
        },
        "text": {
          "type": "string",
          "description": "Provider-rendered compact source window selected from parser-owned context."
        },
        "lines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/line"
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
