{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-hook-activation.v1.schema.json",
  "title": "Semantic Agent Hook Project Activation",
  "description": "Repository-local activation data selecting static provider manifests for the agent-semantic-hook runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "projectRoot",
    "generatedBy",
    "providers"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.hook.activation"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.hook"
    },
    "protocolVersion": {
      "const": "1"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "$ref": "#/$defs/generatedBy"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/activatedProvider"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "pathPattern": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/"
      }
    },
    "sourceExtension": {
      "type": "string",
      "pattern": "^\\.[A-Za-z0-9]+$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "version"],
      "properties": {
        "runtime": {
          "const": "agent-semantic-hook"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "activatedProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestId",
        "manifestDigest",
        "languageId",
        "providerId",
        "binary",
        "providerCommandPrefix",
        "coverage"
      ],
      "properties": {
        "manifestId": {
          "$ref": "#/$defs/namespace"
        },
        "manifestDigest": {
          "$ref": "#/$defs/digest"
        },
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "binary": {
          "$ref": "#/$defs/binary"
        },
        "providerCommandPrefix": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageRoots",
        "sourceRoots",
        "configFiles",
        "sourceExtensions",
        "ignoredPathPrefixes"
      ],
      "properties": {
        "packageRoots": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        },
        "sourceRoots": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        },
        "configFiles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        },
        "sourceExtensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceExtension"
          }
        },
        "ignoredPathPrefixes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        }
      }
    }
  }
}
