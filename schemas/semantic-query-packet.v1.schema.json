{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-query-packet.v1.schema.json",
  "title": "Semantic Query Packet",
  "description": "Provider-native parser query packet for compact code extraction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "binary",
    "namespace",
    "method",
    "projectRoot",
    "query",
    "queryTerms",
    "matches",
    "truncated"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-query-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "method": {
      "type": "string",
      "pattern": "^query/[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "ownerPath": {
      "$ref": "#/$defs/projectPath"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "queryTerms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "matchMode": {
      "enum": [
        "exact",
        "fallback-contains",
        "candidate",
        "mixed",
        "unknown"
      ]
    },
    "outputMode": {
      "description": "Agent-facing rendering mode for matches. Code mode includes compact code; names and outline modes may omit code.",
      "enum": [
        "code",
        "names",
        "outline"
      ]
    },
    "queryCoverage": {
      "type": "array",
      "description": "Per-term coverage for query-set or owner-local item queries.",
      "items": {
        "$ref": "#/$defs/queryCoverage"
      }
    },
    "candidateItems": {
      "type": "array",
      "description": "Bounded parser-owned item names suggested when one or more query terms miss.",
      "items": {
        "$ref": "#/$defs/candidateItem"
      }
    },
    "semanticHandles": {
      "type": "array",
      "description": "Stable non-code semantic facts, such as policy rules, schema fixtures, test cases, config keys, or provider capabilities.",
      "items": {
        "$ref": "semantic-handle.v1.schema.json#/$defs/semanticHandle"
      }
    },
    "syntaxQueryRef": {
      "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxQueryRef"
    },
    "syntaxMatchRefs": {
      "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxMatchRefs"
    },
    "syntaxCaptureRefs": {
      "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxCaptureRefs"
    },
    "syntaxAnchor": {
      "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxAnchor"
    },
    "nativeSyntaxFacts": {
      "type": "array",
      "description": "Parser-owned language syntax facts used for code-shaped query repair and routing.",
      "items": {
        "$ref": "semantic-native-syntax-fact-index.v1.schema.json#/$defs/nativeSyntaxFact"
      }
    },
    "patchSafety": {
      "$ref": "#/$defs/patchSafety"
    },
    "matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/match"
      }
    },
    "matchCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total provider-owned match count before any token-control truncation."
    },
    "matchLimit": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum number of matches serialized in this packet."
    },
    "matchesTruncated": {
      "type": "boolean",
      "description": "Whether matches were truncated for token control. Use exact owner query or a narrower item query when more matches are needed."
    },
    "truncated": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/projectPath"
    },
    "location": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/location"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "location",
        "truncated"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "unknown"
          ]
        },
        "doc": {
          "type": "boolean"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
        },
        "code": {
          "type": "string",
          "description": "Agent-facing compact code projection. This is parser-owned understanding text, not necessarily exact editable source. Line-protocol code text fields and --code output serialize this same projection value."
        },
        "contentKind": {
          "const": "source-code"
        },
        "criticality": {
          "$ref": "semantic-content-compaction.v1.schema.json#/$defs/criticality"
        },
        "compaction": {
          "$ref": "semantic-content-compaction.v1.schema.json#/$defs/compaction"
        },
        "projection": {
          "$ref": "#/$defs/projection"
        },
        "outline": {
          "$ref": "#/$defs/outline"
        },
        "patchSafety": {
          "$ref": "#/$defs/patchSafety"
        },
        "truncated": {
          "type": "boolean"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      }
    },
    "sourceLocator": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/sourceSpanLocator"
    },
    "patchSafety": {
      "description": "Whether compact query output is safe only for navigation/read, or is stable enough to feed asp ast-patch verification. This never makes compact code a text patch preimage; text patch context must come from exact source reads.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "reason"
          ],
          "properties": {
            "level": {
              "enum": [
                "navigation-safe",
                "read-safe"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "nextAction": {
              "type": "string",
              "minLength": 1
            },
            "exactRead": {
              "$ref": "#/$defs/sourceLocator"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "target",
            "preimageSource",
            "sourceFingerprint",
            "parserVersion",
            "allowedOperations"
          ],
          "properties": {
            "level": {
              "enum": [
                "patch-verify-safe",
                "ast-patch-safe"
              ]
            },
            "target": {
              "$ref": "#/$defs/patchTarget"
            },
            "preimageSource": {
              "const": "exact-read",
              "description": "Source of the text preimage used for final patch context. Compact projection code is not valid patch context."
            },
            "sourceFingerprint": {
              "type": "string",
              "minLength": 1
            },
            "parserVersion": {
              "type": "string",
              "minLength": 1
            },
            "allowedOperations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/patchOperation"
              },
              "uniqueItems": true
            },
            "mutationSource": {
              "enum": [
                "provider-native",
                "agent-snippet",
                "codex-text-fallback"
              ]
            },
            "snippetRequired": {
              "type": "boolean"
            },
            "codeInPrompt": {
              "type": "boolean"
            },
            "losslessStructure": {
              "const": true
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "patchTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownerPath",
        "locator",
        "read",
        "location"
      ],
      "properties": {
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "read": {
          "$ref": "#/$defs/sourceLocator"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "itemName": {
          "type": "string",
          "minLength": 1
        },
        "itemKind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "patchOperation": {
      "enum": [
        "append_to_block",
        "insert_before_statement",
        "insert_after_statement",
        "replace_statement",
        "replace_expression",
        "replace_call_arg",
        "insert_import",
        "remove_import",
        "remove_statement",
        "remove_item",
        "replace_item",
        "split_owner_items"
      ]
    },
    "projection": {
      "type": "object",
      "description": "How the provider projected native parser facts into agent-facing code or outline text.",
      "additionalProperties": false,
      "required": [
        "mode",
        "syntax",
        "sourceAuthority"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "compact"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "sourceFingerprint",
              "losslessStructure",
              "exactRead",
              "nodes",
              "renderedNodeIds",
              "renderedRows",
              "nodeCount",
              "nodeLimit",
              "nodesTruncated",
              "omitted",
              "expandActions"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "syntax": {
                "enum": [
                  "save-token-rustfmt",
                  "save-token-ruff",
                  "save-token-typescript"
                ]
              }
            },
            "required": [
              "syntax"
            ]
          },
          "then": {
            "required": [
              "compactSafety"
            ],
            "properties": {
              "mode": {
                "const": "compact"
              },
              "sourceAuthority": {
                "const": "native-parser"
              },
              "compactSafety": {
                "required": [
                  "literalPolicy",
                  "whitespacePolicy",
                  "normalization",
                  "alignment",
                  "exactReadRequired"
                ],
                "properties": {
                  "whitespacePolicy": {
                    "const": "formatter-structural"
                  },
                  "exactReadRequired": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      ],
      "properties": {
        "mode": {
          "enum": [
            "names",
            "outline",
            "compact",
            "exact"
          ]
        },
        "syntax": {
          "enum": [
            "token-compact",
            "brace-block",
            "semantic-outline",
            "save-token-rustfmt",
            "save-token-ruff",
            "save-token-typescript",
            "exact-source",
            "none"
          ]
        },
        "sourceAuthority": {
          "enum": [
            "native-parser",
            "parser-index",
            "source-range"
          ]
        },
        "compactSafety": {
          "type": "object",
          "description": "Provider-owned safety summary for compact text. Compact renderers may remove syntax trivia, but literal bodies and indentation-sensitive payloads must either be preserved, summarized, or routed to exactRead instead of being whitespace-minified.",
          "additionalProperties": false,
          "required": [
            "literalPolicy",
            "whitespacePolicy",
            "exactReadRequired"
          ],
          "properties": {
            "literalPolicy": {
              "enum": [
                "preserve",
                "summarize",
                "omit"
              ],
              "description": "How string, raw string, byte string, char, and equivalent language literal payloads are represented in compact text."
            },
            "whitespacePolicy": {
              "enum": [
                "syntax-trivia-only",
                "semantic-outline",
                "formatter-structural",
                "exact-source"
              ],
              "description": "Which whitespace may be removed. syntax-trivia-only means provider tokenization proved the whitespace is outside literal payloads and indentation-sensitive source regions."
            },
            "normalization": {
              "enum": [
                "none",
                "formatter-assisted"
              ],
              "description": "Whether a provider used a language/workspace formatter as an opaque normalization safety stage. Formatter name, version, and style remain provider-owned metadata outside the shared enum."
            },
            "alignment": {
              "enum": [
                "not-required",
                "parser-roundtrip",
                "formatter-roundtrip"
              ],
              "description": "Strongest structural alignment check completed before trusting the compact text."
            },
            "exactReadRequired": {
              "type": "boolean",
              "description": "Whether agents must expand exactRead before relying on literal payloads, original indentation, comments, or text-patch context."
            }
          }
        },
        "sourceFingerprint": {
          "type": "string",
          "description": "Provider-owned fingerprint for the source slice used to build this projection. Agents use this to detect stale compact projections before editing.",
          "minLength": 1
        },
        "losslessStructure": {
          "type": "boolean",
          "description": "Whether block ownership and control-flow structure are preserved by the projection."
        },
        "exactRead": {
          "type": "string",
          "description": "Exact source locator to use before editing.",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
        },
        "nodes": {
          "type": "array",
          "description": "Parser-owned reasoning nodes that generated the compact text. Nodes are the reverse-navigation surface from projection back to exact source blocks.",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projectionNode"
          }
        },
        "renderedNodeIds": {
          "type": "array",
          "description": "Projection node ids that own a primary rendered compact row. A node id may appear at most once here; repeated mentions in labels, edges, omitted facts, or expand actions are references, not duplicate rendered rows.",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.:-]+$"
          }
        },
        "renderedRows": {
          "type": "array",
          "description": "Prompt-facing compact rows, each bound to exactly one parser-owned projection node. When matches[].code is present, providers join renderedRows[].text with newlines to produce that code string.",
          "items": {
            "$ref": "#/$defs/projectionRenderedRow"
          }
        },
        "semanticResponsibilities": {
          "type": "array",
          "description": "Parser-owned functional responsibilities represented by this projection but not necessarily rendered in compact text. Agents use these as explicit complexity and edit-planning facts, not inferred labels.",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projectionResponsibility"
          }
        },
        "nodeCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total provider-owned projection node count before any token-control truncation."
        },
        "nodeLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of projection nodes serialized in this packet."
        },
        "nodesTruncated": {
          "type": "boolean",
          "description": "Whether projection nodes were truncated for token control. Use exactRead or expandActions for full source navigation."
        },
        "expandActionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total provider-owned expand action count before any token-control truncation."
        },
        "expandActionLimit": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of expand actions serialized in this packet."
        },
        "expandActionsTruncated": {
          "type": "boolean",
          "description": "Whether expand actions were truncated for token control. Use exactRead or query the selected owner when more expansion is needed."
        },
        "omitted": {
          "type": "array",
          "description": "Facts intentionally omitted from compact text for token control, with enough metadata for an agent to decide whether to expand.",
          "items": {
            "$ref": "#/$defs/projectionOmission"
          }
        },
        "expandActions": {
          "type": "array",
          "description": "Provider-native follow-up actions that expand a node, hot block, or exact source range without restarting broad search.",
          "items": {
            "$ref": "#/$defs/expandAction"
          }
        }
      }
    },
    "projectionNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nativeId",
        "kind",
        "role",
        "label",
        "depth",
        "read",
        "structuralFingerprint"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "nativeId": {
          "type": "string",
          "description": "Provider-owned native parser identity for this AST node when available. This is diagnostic metadata; the packet-level projection node id remains the shared reference key.",
          "minLength": 1
        },
        "parentId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "declaration",
            "control-flow",
            "call",
            "field",
            "delimiter",
            "terminal",
            "mutation",
            "effect",
            "unknown"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "depth": {
          "type": "integer",
          "minimum": 0
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
        },
        "structuralFingerprint": {
          "type": "string",
          "description": "Provider-owned structural fingerprint used to diagnose parser/formatter alignment and projection identity stability.",
          "minLength": 1
        },
        "flags": {
          "type": "array",
          "items": {
            "enum": [
              "branch",
              "loop",
              "break",
              "continue",
              "guard",
              "call",
              "field",
              "return",
              "raise",
              "throw",
              "panic",
              "async",
              "await",
              "unsafe",
              "mutation",
              "effect",
              "delimiter"
            ]
          }
        }
      }
    },
    "projectionRenderedRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeId",
        "rowKind",
        "text"
      ],
      "properties": {
        "nodeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "rowKind": {
          "enum": [
            "declaration",
            "mutation",
            "call",
            "control-flow",
            "terminal",
            "effect",
            "field",
            "delimiter",
            "omission",
            "unknown"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "semanticWeight": {
          "type": "integer",
          "minimum": 0,
          "description": "Provider-owned row weight for token-cost and residue metrics."
        }
      }
    },
    "projectionResponsibility": {
      "type": "object",
      "description": "Provider-owned parser-derived responsibility tag with optional projection-node or exact-read evidence.",
      "additionalProperties": false,
      "required": [
        "kind",
        "source"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": [
            "native-parser",
            "projection-node"
          ]
        },
        "nodeId": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
        }
      }
    },
    "projectionOmission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "nodeId": {
          "type": "string",
          "description": "Projection node id this omitted fact belongs to, when the omission is node-local.",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*:[1-9][0-9]*$"
        }
      }
    },
    "expandAction": {
      "type": "object",
      "description": "Projection-local expansion action. Routing actions such as owner-local name listing are query/candidate output, not compact AST projection actions.",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "exact-read"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "read"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "hot-block"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "read"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "node-query"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "capabilityId",
              "selector"
            ],
            "not": {
              "required": [
                "read"
              ]
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": [
            "exact-read",
