{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-hook-provider-manifest.v1.schema.json",
  "title": "Semantic Agent Hook Provider Manifest",
  "description": "Static provider-owned facts used by agent-semantic-hook after a workspace activation selects the provider.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "manifestId",
    "manifestVersion",
    "languageId",
    "providerId",
    "namespace",
    "binary",
    "source",
    "policy",
    "routes"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.hook.provider-manifest"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.hook"
    },
    "protocolVersion": {
      "const": "1"
    },
    "manifestId": {
      "$ref": "#/$defs/namespace"
    },
    "manifestVersion": {
      "$ref": "#/$defs/identifier"
    },
    "languageId": {
      "$ref": "#/$defs/identifier"
    },
    "providerId": {
      "$ref": "#/$defs/identifier"
    },
    "namespace": {
      "$ref": "#/$defs/namespace"
    },
    "binary": {
      "$ref": "#/$defs/binary"
    },
    "source": {
      "$ref": "#/$defs/sourceDefaults"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "routes": {
      "$ref": "#/$defs/routes"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "pathPattern": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/"
      }
    },
    "sourceExtension": {
      "type": "string",
      "pattern": "^\\.[A-Za-z0-9]+$"
    },
    "sourceDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultExtensions",
        "defaultConfigFiles",
        "defaultSourceRoots",
        "defaultIgnoredPathPrefixes"
      ],
      "properties": {
        "defaultExtensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceExtension"
          }
        },
        "defaultConfigFiles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        },
        "defaultSourceRoots": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        },
        "defaultIgnoredPathPrefixes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pathPattern"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directSourceRead",
        "bulkSourceDump",
        "rawSourceSearch",
        "agentSearchJson"
      ],
      "properties": {
        "directSourceRead": {
          "$ref": "#/$defs/actionPolicy"
        },
        "bulkSourceDump": {
          "$ref": "#/$defs/actionPolicy"
        },
        "rawSourceSearch": {
          "$ref": "#/$defs/actionPolicy"
        },
        "agentSearchJson": {
          "$ref": "#/$defs/actionPolicy"
        }
      }
    },
    "actionPolicy": {
      "enum": ["block", "allow", "advisory"]
    },
    "routes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prime", "owner", "fzf", "ingest", "checkChanged"],
      "properties": {
        "prime": {
          "$ref": "#/$defs/commandTemplate"
        },
        "owner": {
          "$ref": "#/$defs/commandTemplate"
        },
        "query": {
          "$ref": "#/$defs/commandTemplate"
        },
        "ingest": {
          "$ref": "#/$defs/commandTemplate"
        },
        "checkChanged": {
          "$ref": "#/$defs/commandTemplate"
        },
        "guide": {
          "$ref": "#/$defs/commandTemplate"
        },
        "fzf": {
          "$ref": "#/$defs/commandTemplate"
        },
        "exportIndex": {
          "$ref": "#/$defs/commandTemplate"
        }
      }
    },
    "commandTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "stdinMode": {
          "enum": ["none", "pipe-candidates", "pipe-diff", "unknown"]
        }
      }
    }
  }
}
