{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/python-semantic-capabilities-template.v1.schema.json",
  "title": "Python Semantic Capabilities Template",
  "description": "Protocol-repository template for Python provider-specific semantic capability schemas. Active provider schemas live inside the Python harness repository.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "schemaVersion", "languageId", "providerId"],
  "properties": {
    "schemaId": {
      "type": "string",
      "pattern": "^agent\\.semantic-protocols\\.languages\\.python\\.[a-z][a-z0-9_-]*\\.capabilities$"
    },
    "schemaVersion": {
      "const": "1"
    },
    "languageId": {
      "const": "python"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "capability": {
      "$ref": "#/$defs/capabilityDescriptor"
    },
    "ingestSurface": {
      "$ref": "#/$defs/ingestSurfaceDescriptor"
    }
  },
  "$defs": {
    "namespace": {
      "enum": ["semantic", "python"]
    },
    "capabilityDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "namespace", "name"],
      "properties": {
        "languageId": {
          "const": "python"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "workspace-router",
            "python-package-root-search",
            "package-prime-map",
            "python-reasoning-tree-prime",
            "python-entry-point-search",
            "reasoning-owner-search",
            "parser-visible-module-owner-search",
            "python-owner-item-query",
            "pytest-test-owner-search",
            "path-owner-fallback",
            "dependency-manifest-search",
            "dependency-local-usage-search",
            "dependency-version-scope",
            "dependency-api-token-usage-search",
            "exported-api-shape-search",
            "public-function-api-shape-search",
            "public-data-api-shape-search",
            "public-external-type-search",
            "public-api-type-text-search",
            "policy-rule-handle-search",
            "python-project-policy-rule-handle-search",
            "python-agent-policy-rule-handle-search",
            "symbol-definition-search",
            "owner-callsite-search",
            "import-edge-search",
            "owner-path-text-search",
            "export-text-search",
            "parser-visible-source-text-search",
            "finder-fuzzy-candidate-search",
            "parser-visible-source-fuzzy-search",
            "external-candidate-ingest",
            "stdin-shape-detection",
            "owner-grouped-ingest"
          ]
        }
      }
    },
    "ingestSurfaceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "namespace", "name"],
      "properties": {
        "languageId": {
          "const": "python"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "non-parser-path",
            "non-parser-text",
            "docs-text",
            "external-api-docs",
            "schema-json",
            "generated-artifact"
          ]
        }
      }
    }
  }
}
