{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent.semantic-protocols.semantic-tree-sitter-query.v1",
  "title": "ASP Semantic Tree-sitter Query Packet",
  "type": "object",
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "method",
    "projectRoot",
    "grammarId",
    "sourceAuthority",
    "execution",
    "query",
    "matches",
    "nativeFactRefs",
    "truncated",
    "cache"
  ],
  "properties": {
    "schemaId": { "const": "agent.semantic-protocols.semantic-tree-sitter-query" },
    "schemaVersion": { "const": "1" },
    "protocolId": { "const": "agent.semantic-protocols.semantic-language" },
    "protocolVersion": { "const": "1" },
    "languageId": { "type": "string", "minLength": 1 },
    "providerId": { "type": "string", "minLength": 1 },
    "method": { "const": "query" },
    "projectRoot": { "type": "string", "minLength": 1 },
    "grammarId": { "type": "string", "minLength": 1 },
    "sourceAuthority": { "enum": ["native-parser", "codeql"] },
    "adapterMode": {
      "enum": ["tree-sitter-querycursor", "codeql-query"]
    },
    "compatibilityLevel": {
      "enum": ["native-only", "approximate"]
    },
    "executionBackend": {
      "enum": ["native-parser", "codeql"]
    },
    "execution": {
      "type": "object",
      "required": [
        "engine",
        "predicateEvaluator",
        "matchStatus",
        "selectedFileCount",
        "parsedFileCount",
        "queryCompileCount",
        "cursorMatchCount",
        "elapsedMs"
      ],
      "properties": {
        "engine": { "enum": ["tree-sitter-querycursor", "codeql"] },
        "predicateEvaluator": {
          "enum": ["asp-tree-sitter-predicate-v1", "codeql"]
        },
        "matchStatus": { "enum": ["hit", "miss", "unsupported", "invalid"] },
        "unsupportedPredicates": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "selectedFileCount": { "type": "integer", "minimum": 0 },
        "parsedFileCount": { "type": "integer", "minimum": 0 },
        "queryCompileCount": { "type": "integer", "minimum": 0 },
        "cursorMatchCount": { "type": "integer", "minimum": 0 },
        "elapsedMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "query": {
      "type": "object",
      "required": ["input", "inputForm", "dialect", "grammarProfilePath", "compiledSource", "fields"],
      "properties": {
        "input": { "type": "string" },
        "inputForm": { "enum": ["catalog-id", "s-expression"] },
        "dialect": { "const": "tree-sitter-query" },
        "catalogId": { "type": "string" },
        "catalogPath": { "type": "string" },
        "grammarProfilePath": { "type": "string" },
        "compiledSource": { "type": "string" },
        "fields": {
          "type": "object",
          "properties": {
            "predicates": {
              "type": "array",
              "items": { "type": "object" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "matches": { "type": "array" },
    "nativeFactRefs": { "type": "array" },
    "truncated": { "type": "boolean" },
    "cache": { "type": "object" }
  },
  "additionalProperties": true
}
