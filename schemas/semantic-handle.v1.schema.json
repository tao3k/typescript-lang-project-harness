{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-handle.v1.schema.json",
  "title": "Semantic Handle",
  "description": "Language-neutral stable handles for semantic facts that are not necessarily parser items.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "projectRoot",
    "handles"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-handle"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "enum": [
        "workspace",
        "prime",
        "owner",
        "policy",
        "schema",
        "tests",
        "dependency",
        "query",
        "custom"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "handles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/semanticHandle"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "scalar": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "lineRange"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "lineRange": {
          "type": "string",
          "description": "Compact source line range as start:end, for example 10:43. This is display metadata, not selector identity.",
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
        },
        "structuralSelector": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9+.-]*://[^#\\s]+#[^\\s]+$"
        },
        "displayLineRange": {
          "type": "string",
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
        },
        "sourceLocatorHint": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*(?:(?::|-)[1-9][0-9]*)?$"
        }
      }
    },
    "handleKind": {
      "enum": [
        "policy-rule",
        "schema-fixture",
        "test-case",
        "config-key",
        "command",
        "capability",
        "dependency-api",
        "public-api",
        "owner",
        "item",
        "build-target",
        "runtime-receipt",
        "custom"
      ]
    },
    "handleSource": {
      "enum": [
        "native-parser",
        "provider-policy",
        "schema",
        "manifest",
        "test-index",
        "runtime",
        "registry",
        "custom"
      ]
    },
    "handleStatus": {
      "enum": [
        "active",
        "advisory",
        "deprecated",
        "blocked",
        "unknown"
      ]
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "properties": {
        "kind": {
          "enum": [
            "implements",
            "tests",
            "documents",
            "depends-on",
            "supersedes",
            "related",
            "custom"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "semanticHandle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "source",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/handleKind"
        },
        "source": {
          "$ref": "#/$defs/handleSource"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "languageName": {
          "type": "string",
          "minLength": 1
        },
        "qualifiedName": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "labels": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "$ref": "#/$defs/handleStatus"
        },
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "structuralSelector": {
          "type": "string",
          "description": "Parser-owned stable selector for this handle. This is the executable semantic identity when present.",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9+.-]*://[^#\\s]+#[^\\s]+$"
        },
        "nativeFactId": {
          "type": "string",
          "description": "Provider-native fact id usable as a semantic handle within the provider packet.",
          "minLength": 1
        },
        "displayLineRange": {
          "type": "string",
          "description": "Human display line range. This is not an executable selector.",
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
        },
        "sourceLocatorHint": {
          "type": "string",
          "description": "Compatibility source locator for exact code transport after a semantic selector has been chosen.",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*(?:(?::|-)[1-9][0-9]*)?$"
        },
        "projection": {
          "enum": [
            "outline",
            "names",
            "signature",
            "doc",
            "children",
            "content",
            "code"
          ]
        },
        "codePolicy": {
          "enum": [
            "no-code",
            "code-after-exact-selector",
            "requires-exact-code"
          ]
        },
        "implementationOwnerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "testPaths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projectPath"
          }
        },
        "locations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/location"
          }
        },
        "queryTerms": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
