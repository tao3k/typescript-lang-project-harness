{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-dev-command-log.v1.schema.json",
  "title": "Semantic Dev Command Log Event",
  "description": "One JSONL event emitted by a semantic language provider when SEMANTIC_PROTOCOL_DEV_MODE=1 is enabled.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "timestampUtc",
    "startedAtUtc",
    "finishedAtUtc",
    "eventId",
    "sessionId",
    "sessionOrdinal",
    "languageId",
    "providerId",
    "binary",
    "argv",
    "cwd",
    "projectRoot",
    "projectRootHash",
    "command",
    "result"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.dev-command-log"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time"
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "sessionOrdinal": {
      "type": "integer",
      "minimum": 0
    },
    "parentEventId": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "cwd": {
      "type": "string",
      "minLength": 1
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "projectRootHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{16,64}$"
    },
    "hookRunId": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "$ref": "#/$defs/command"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "method"
      ],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "method": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(/[a-z][a-z0-9_-]*)*$"
        },
        "view": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "renderMode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "query": {
          "type": "string"
        },
        "querySetCount": {
          "type": "integer",
          "minimum": 0
        },
        "pipes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitCode",
        "elapsedMs",
        "stdoutBytes",
        "stderrBytes"
      ],
      "properties": {
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        },
        "stdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "stderrBytes": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "enum": [
            "success",
            "failure"
          ]
        }
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          }
        ]
      }
    }
  }
}
