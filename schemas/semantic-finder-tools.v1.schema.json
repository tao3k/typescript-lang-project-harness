{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-finder-tools.v1.schema.json",
  "title": "Semantic Finder Tools",
  "description": "Shared contract for provider-approved lexical, fuzzy, path, and structural finder pipelines used by semantic search.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "projectRoot",
    "toolCatalog",
    "pipelines"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-finder-tools"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "toolCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "pipelines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pipeline"
      }
    },
    "provenanceSamples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finderProvenance"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "toolId": {
      "enum": [
        "rg",
        "fzf",
        "fd",
        "ast-grep",
        "ugrep",
        "provider-index",
        "custom"
      ]
    },
    "toolRole": {
      "enum": [
        "source-scan",
        "fuzzy-filter",
        "path-list",
        "structural-search",
        "candidate-normalizer",
        "scoring",
        "custom"
      ]
    },
    "toolBoundary": {
      "enum": [
        "lexical-candidate",
        "fuzzy-filter",
        "path-candidate",
        "structural-recipe",
        "provider-index",
        "adapter-only",
        "custom"
      ]
    },
    "dataFormat": {
      "enum": [
        "rg-json",
        "rg-n",
        "vimgrep",
        "path-list",
        "path-list-nul",
        "line-list",
        "owner-labels",
        "structural-matches",
        "jsonl",
        "custom"
      ]
    },
    "stageMode": {
      "enum": [
        "literal",
        "fixed",
        "regex",
        "word",
        "case-folded",
        "fuzzy",
        "structural",
        "recipe",
        "normalize",
        "custom"
      ]
    },
    "surface": {
      "enum": [
        "search-fzf",
        "search-fzf",
        "search-ingest",
        "search-pattern",
        "provider-internal",
        "custom"
      ]
    },
    "candidateBasis": {
      "enum": [
        "source-lines",
        "paths",
        "owner-labels",
        "structural-matches",
        "mixed",
        "custom"
      ]
    },
    "toolSupport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headless",
        "interactive",
        "json",
        "fuzzy",
        "regex",
        "structural",
        "rewrite"
      ],
      "properties": {
        "headless": { "type": "boolean" },
        "interactive": { "type": "boolean" },
        "json": { "type": "boolean" },
        "fuzzy": { "type": "boolean" },
        "regex": { "type": "boolean" },
        "structural": { "type": "boolean" },
        "rewrite": { "type": "boolean" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolId",
        "displayName",
        "roles",
        "boundary",
        "inputFormats",
        "outputFormats",
        "supports",
        "agentCallable"
      ],
      "properties": {
        "toolId": {
          "$ref": "#/$defs/toolId"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/toolRole"
          }
        },
        "boundary": {
          "$ref": "#/$defs/toolBoundary"
        },
        "inputFormats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dataFormat"
          }
        },
        "outputFormats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dataFormat"
          }
        },
        "supports": {
          "$ref": "#/$defs/toolSupport"
        },
        "agentCallable": {
          "type": "boolean"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "toolId": { "const": "ast-grep" }
            },
            "required": ["toolId"]
          },
          "then": {
            "properties": {
              "boundary": { "const": "structural-recipe" },
              "supports": {
                "properties": {
                  "fuzzy": { "const": false },
                  "structural": { "const": true }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "toolId": { "const": "fzf" }
            },
            "required": ["toolId"]
          },
          "then": {
            "properties": {
              "boundary": { "const": "fuzzy-filter" },
              "supports": {
                "properties": {
                  "headless": { "const": true },
                  "fuzzy": { "const": true }
                }
              }
            }
          }
        }
      ]
    },
    "pipelineStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "toolId",
        "role",
        "mode",
        "inputFormat",
        "outputFormat",
        "headlessRequired",
        "agentAuthoredArgsAllowed"
      ],
      "properties": {
        "stageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "toolId": {
          "$ref": "#/$defs/toolId"
        },
        "role": {
          "$ref": "#/$defs/toolRole"
        },
        "mode": {
          "$ref": "#/$defs/stageMode"
        },
        "inputFormat": {
          "$ref": "#/$defs/dataFormat"
        },
        "outputFormat": {
          "$ref": "#/$defs/dataFormat"
        },
        "headlessRequired": {
          "type": "boolean"
        },
        "agentAuthoredArgsAllowed": {
          "type": "boolean"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "toolId": { "const": "fzf" }
            },
            "required": ["toolId"]
          },
          "then": {
            "properties": {
              "role": { "const": "fuzzy-filter" },
              "mode": { "const": "fuzzy" },
              "headlessRequired": { "const": true },
              "agentAuthoredArgsAllowed": { "const": false }
            }
          }
        },
        {
          "if": {
            "properties": {
              "toolId": { "const": "ast-grep" }
            },
            "required": ["toolId"]
          },
          "then": {
            "properties": {
              "role": { "const": "structural-search" },
              "mode": {
                "enum": ["structural", "recipe"]
              },
              "agentAuthoredArgsAllowed": { "const": false }
            }
          }
        }
      ]
    },
    "pipelineOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateBasis", "emitsRawSource"],
      "properties": {
        "candidateBasis": {
          "$ref": "#/$defs/candidateBasis"
        },
        "emitsRawSource": {
          "type": "boolean"
        },
        "maxCandidates": {
          "type": "integer",
          "minimum": 1
        },
        "next": {
          "type": "array",
          "items": {
            "enum": ["owner-grouping", "nearest-item", "tests", "query", "ingest"]
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipelineId", "surface", "purpose", "stages", "output"],
      "properties": {
        "pipelineId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "surface": {
          "$ref": "#/$defs/surface"
        },
        "purpose": {
          "enum": [
            "lexical-candidates",
            "path-candidates",
            "fuzzy-lexical-candidates",
            "structural-candidates",
            "hybrid-evidence",
            "custom"
          ]
        },
        "defaultFor": {
          "type": "array",
          "items": {
            "enum": ["fzf", "text", "text-fuzzy", "path", "pattern", "ingest"]
          }
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pipelineStage"
          }
        },
        "output": {
          "$ref": "#/$defs/pipelineOutput"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "stageProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stageId",
        "toolId",
        "role",
        "inputFormat",
        "outputFormat",
        "candidatesIn",
        "candidatesOut"
      ],
      "properties": {
        "stageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "toolId": {
          "$ref": "#/$defs/toolId"
        },
        "role": {
          "$ref": "#/$defs/toolRole"
        },
        "inputFormat": {
          "$ref": "#/$defs/dataFormat"
        },
        "outputFormat": {
          "$ref": "#/$defs/dataFormat"
        },
        "candidatesIn": {
          "type": "integer",
          "minimum": 0
        },
        "candidatesOut": {
          "type": "integer",
          "minimum": 0
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "finderProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipelineId",
        "backend",
        "matchMode",
        "candidateBasis",
        "sourceSearchPasses",
        "inputCandidates",
        "selectedCandidates",
        "stages"
      ],
      "properties": {
        "pipelineId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "backend": {
          "enum": ["rg", "rg+fzf", "fzf", "ugrep", "ast-grep", "provider-index", "custom"]
        },
        "matchMode": {
          "$ref": "#/$defs/stageMode"
        },
        "candidateBasis": {
          "$ref": "#/$defs/candidateBasis"
        },
        "sourceSearchPasses": {
          "type": "integer",
          "minimum": 0
        },
        "inputCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "selectedCandidates": {
          "type": "integer",
          "minimum": 0
        },
        "fuzzyFilter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["toolId", "query"],
          "properties": {
            "toolId": {
              "const": "fzf"
            },
            "query": {
              "type": "string",
              "minLength": 1
            },
            "scoreBasis": {
              "enum": ["rank", "score", "order", "custom"]
            }
          }
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stageProvenance"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    }
  }
}
