{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-verification-receipt.v1.schema.json",
  "title": "Semantic Verification Receipt",
  "description": "Executable evidence receipt emitted by a verification tool adapter such as cargo check, cargo test, clippy, expect-test, proptest, cargo-fuzz, Kani, Creusot, or Verus.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "receiptId",
    "producer",
    "tool",
    "status",
    "command",
    "summary",
    "observations"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-verification-receipt"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.verification-receipt"
    },
    "protocolVersion": {
      "const": "1"
    },
    "receiptId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    },
    "producer": {
      "$ref": "#/$defs/producer"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "tool": {
      "$ref": "#/$defs/tool"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "command": {
      "$ref": "#/$defs/command"
    },
    "exitCode": {
      "type": "integer"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "observedAt": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    },
    "candidateIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "taskFingerprints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "providerId", "adapterId"],
      "properties": {
        "languageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "providerId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "adapterId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "workdir": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tool": {
      "enum": [
        "cargo-check",
        "cargo-test",
        "clippy",
        "expect-test",
        "proptest",
        "cargo-fuzz",
        "kani",
        "creusot",
        "verus"
      ]
    },
    "status": {
      "enum": ["passed", "failed", "skipped", "error"]
    },
    "outputFormat": {
      "enum": [
        "cargo-json",
        "plain-text",
        "libtest",
        "expect-test",
        "fuzz-corpus",
        "proof-report",
        "unknown"
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "workdir": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "outputFormat": {
          "$ref": "#/$defs/outputFormat"
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "enum": [
            "exit-status",
            "stdout",
            "stderr",
            "diagnostic",
            "test-result",
            "snapshot-diff",
            "coverage",
            "artifact",
            "note"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": {
          "enum": [
            "stdout",
            "stderr",
            "cargo-json",
            "expect-snapshot",
            "coverage-report",
            "proof-log",
            "fuzz-artifact",
            "other"
          ]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    }
  }
}
