{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-native-syntax-fact-index.v1.schema.json",
  "title": "Semantic Native Syntax Fact Index",
  "description": "Language-neutral parser-owned syntax facts used by semantic language providers before falling back to text search.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "projectRoot",
    "facts"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-native-syntax-fact-index"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "enum": [
        "workspace",
        "prime",
        "owner",
        "query",
        "changed",
        "custom"
      ]
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "queryIntent": {
      "$ref": "#/$defs/queryIntent"
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nativeSyntaxFact"
      }
    },
    "indexes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/indexDescriptor"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "scalar": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "projectPath": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/projectPath"
    },
    "location": {
      "$ref": "semantic-source-location.v1.schema.json#/$defs/location"
    },
    "factKind": {
      "enum": [
        "module",
        "owner",
        "item",
        "function",
        "method",
        "class",
        "struct",
        "enum",
        "interface",
        "trait",
        "type",
        "import",
        "export",
        "reexport",
        "argument",
        "binding",
        "call",
        "constant",
        "doc",
        "field",
        "include",
        "macro",
        "attribute",
        "decorator",
        "test",
        "public-api",
        "dependency-api",
        "config",
        "custom"
      ]
    },
    "factSource": {
      "enum": [
        "native-parser",
        "type-checker",
        "manifest",
        "test-index",
        "provider-policy",
        "custom"
      ]
    },
    "visibility": {
      "enum": [
        "public",
        "private",
        "protected",
        "internal",
        "crate",
        "super",
        "self",
        "package",
        "module",
        "restricted",
        "unknown"
      ]
    },
    "queryIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "term"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
        },
        "term": {
          "type": "string",
          "minLength": 1
        },
        "languageKind": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "properties": {
        "kind": {
          "enum": [
            "contains",
            "imports",
            "exports",
            "reexports",
            "calls",
            "tests",
            "implements",
            "references",
            "related",
            "custom"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "nativeSyntaxFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "source",
        "ownerPath"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/factKind"
        },
        "source": {
          "$ref": "#/$defs/factSource"
        },
        "languageKind": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "qualifiedName": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "exported": {
          "type": "boolean"
        },
        "test": {
          "type": "boolean"
        },
        "queryKeys": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
          "syntaxQueryRef": {
            "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxQueryRef"
          },
          "syntaxMatchRefs": {
            "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxMatchRefs"
          },
          "syntaxCaptureRefs": {
            "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxCaptureRefs"
        },
        "syntaxAnchor": {
          "$ref": "semantic-tree-sitter-provenance.v1.schema.json#/$defs/syntaxAnchor"
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "indexDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "factKinds"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "factKinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/factKind"
          }
        },
        "queryKeys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
