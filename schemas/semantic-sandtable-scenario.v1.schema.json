{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-sandtable-scenario.v1.schema.json",
  "title": "Semantic Sandtable Scenario",
  "description": "Language-neutral scenario descriptor for replaying bounded agent search flows against semantic language harness CLIs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "language", "workdir", "steps"],
  "allOf": [
    {
      "if": {
        "required": ["evidence"],
        "properties": {
          "evidence": {
            "type": "object",
            "required": ["fixtureTier"],
            "properties": {
              "fixtureTier": {
                "const": "large-library"
              }
            }
          }
        }
      },
      "then": {
        "required": ["coverage"],
        "properties": {
          "coverage": {
            "contains": {
              "const": "large-library"
            }
          }
        }
      }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "coverage": {
      "$ref": "#/$defs/coverageList"
    },
    "tags": {
      "$ref": "#/$defs/stringList"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "workdir": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/workdir"
        }
      ]
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "allOf": [
        {
          "if": {
            "required": ["fixtureTier"],
            "properties": {
              "fixtureTier": {
                "const": "large-library"
              }
            }
          },
          "then": {
            "required": ["targetLibrary", "intentCases"],
            "properties": {
              "targetLibrary": {
                "required": ["repository"],
                "properties": {
                  "workdirKind": {
                    "enum": ["checkout", "registry"]
                  }
                }
              },
              "intentCases": {
                "minItems": 3,
                "allOf": [
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "feature-implementation"
                        }
                      }
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "api-usage"
                        }
                      }
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "implementation-principle"
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      ],
      "properties": {
        "source": {
          "enum": ["handwritten", "real-trigger", "recorded-replay"]
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "intentKind": {
          "$ref": "#/$defs/intentKind"
        },
        "targetLibrary": {
          "$ref": "#/$defs/targetLibrary"
        },
        "fixtureTier": {
          "enum": ["large-library"]
        },
        "intentCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/intentCase"
          }
        },
        "recordedAt": {
          "type": "string",
          "minLength": 1
        },
        "receiptPath": {
          "type": "string",
          "minLength": 1
        },
        "editBoundary": {
          "enum": ["before-edit", "after-search", "none", "unknown"]
        },
        "metrics": {
          "$ref": "#/$defs/evidenceMetrics"
        },
        "querySetOpportunities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/querySetOpportunity"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceFinding"
          }
        }
      }
    },
    "intentKind": {
      "enum": [
        "feature-implementation",
        "api-usage",
        "implementation-principle"
      ]
    },
    "targetLibrary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "name", "package", "workdirKind"],
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "workdirKind": {
          "enum": ["checkout", "registry", "unknown"]
        }
      }
    },
    "intentCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentKind", "intent", "stepIds"],
      "properties": {
        "intentKind": {
          "$ref": "#/$defs/intentKind"
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "stepIds": {
          "$ref": "#/$defs/stringList"
        },
        "queryTerms": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "evidenceMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recordedCommandCount": {
          "type": "integer",
          "minimum": 0
        },
        "recordedElapsedMs": {
          "type": "integer",
          "minimum": 0
        },
        "recordedStdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "recordedStderrBytes": {
          "type": "integer",
          "minimum": 0
        },
        "repeatedSearches": {
          "type": "integer",
          "minimum": 0
        },
        "jsonSearches": {
          "type": "integer",
          "minimum": 0
        },
        "compactSearches": {
          "type": "integer",
          "minimum": 0
        },
        "tokenDelta": {
          "enum": ["lower", "same", "higher", "unknown"]
        }
      }
    },
    "querySetOpportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "queries", "saveCommands"],
      "properties": {
        "view": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "queries": {
          "type": "integer",
          "minimum": 2
        },
        "saveCommands": {
          "type": "integer",
          "minimum": 1
        },
        "selector": {
          "enum": ["exact-set", "prefix-set", "stdin-path-set"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "terms": {
          "$ref": "#/$defs/stringList"
        },
        "scope": {
          "$ref": "#/$defs/queryScope"
        },
        "beforeCommandIds": {
          "$ref": "#/$defs/stringList"
        },
        "recommendedCommand": {
          "$ref": "#/$defs/argv"
        }
      }
    },
    "queryScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectRoot": {
          "type": "string",
          "minLength": 1
        },
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "roots": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "evidenceFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workdir": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "relative": {
          "type": "string",
          "minLength": 1
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {"required": ["env"]},
        {"required": ["relative"]},
        {"required": ["candidates"]}
      ]
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxCommands": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalElapsedMsWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalStdoutBytesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalStderrBytesWarn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "kind": {
          "enum": [
            "command",
            "schema-contract",
            "policy-blackbox",
            "policy-whitebox",
            "performance",
            "security",
            "hook-replay",
            "wrapper"
          ]
        },
        "coverage": {
          "$ref": "#/$defs/coverageList"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "command": {
          "$ref": "#/$defs/argv"
        },
        "stdin": {
          "type": "string"
        },
        "stdinCommand": {
          "$ref": "#/$defs/argv"
        },
        "stdinCommandAllowNonZero": {
          "type": "boolean"
        },
        "stdinTimeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "timeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "capture": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "expect": {
          "$ref": "#/$defs/expect"
        }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exitCode": {
          "type": "integer"
        },
        "lineProtocol": {
          "type": "boolean"
        },
        "stdoutContains": {
          "$ref": "#/$defs/stringList"
        },
        "stderrContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutMatches": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutEmpty": {
          "type": "boolean"
        },
        "stdoutJsonEquals": {
          "$ref": "#/$defs/jsonPathMap"
        },
        "stdoutJsonContains": {
          "$ref": "#/$defs/stringMap"
        },
        "stdoutJsonArrayContains": {
          "$ref": "#/$defs/jsonValueMap"
        },
        "stdoutJsonSchema": {
          "type": "string",
          "minLength": 1
        },
        "stdoutJsonSchemaAt": {
          "$ref": "#/$defs/stringMap"
        },
        "guideQuality": {
          "$ref": "#/$defs/guideQuality"
        },
        "maxStdoutLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStderrLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStdoutBytesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxElapsedMsWarn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "guideQuality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasonKind": {
          "type": "string",
          "minLength": 1
        },
        "languageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "routeKind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "commandContains": {
          "$ref": "#/$defs/stringList"
        },
        "outputContains": {
          "$ref": "#/$defs/stringList"
        },
        "outputNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "primeOutput": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requiresStructureStatus": {
              "type": "boolean"
            },
            "entries": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^entries=(?:owner-query|query-deps|owner-tests|finding-frontier|feature-cfg)\\([^)]*\\)(?:,(?:owner-query|query-deps|owner-tests|finding-frontier|feature-cfg)\\([^)]*\\))*$"
              }
            }
          }
        },
        "routeCommandContains": {
          "$ref": "#/$defs/stringList"
        },
        "routeCommandNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "requiresIngestPipe": {
          "type": "boolean"
        },
        "sourceLeakNotContains": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverageList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "language-registry",
          "json-schema",
          "search-flow",
          "deps-query",
          "policy-blackbox",
          "policy-whitebox",
          "performance",
          "security",
          "codex-hooks",
          "codex-wrapper",
          "evidence-assurance",
          "desktop-hooks",
          "cli-hooks",
          "real-trigger",
          "large-library"
        ]
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "jsonPathMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "jsonValueMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        }
      ]
    }
  }
}
