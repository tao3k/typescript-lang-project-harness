{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/typescript-semantic-capabilities-template.v1.schema.json",
  "title": "TypeScript Semantic Capabilities Template",
  "description": "Protocol-repository template for TypeScript provider-specific semantic capability schemas. Active provider schemas live inside the TypeScript harness repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "languageId",
    "providerId"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "pattern": "^agent\\.semantic-protocols\\.languages\\.typescript\\.[a-z][a-z0-9_-]*\\.capabilities$"
    },
    "schemaVersion": {
      "const": "1"
    },
    "languageId": {
      "const": "typescript"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "capability": {
      "$ref": "#/$defs/capabilityDescriptor"
    },
    "ingestSurface": {
      "$ref": "#/$defs/ingestSurfaceDescriptor"
    }
  },
  "$defs": {
    "namespace": {
      "enum": [
        "semantic",
        "typescript"
      ]
    },
    "capabilityDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "languageId",
        "namespace",
        "name"
      ],
      "properties": {
        "languageId": {
          "const": "typescript"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "workspace-router",
            "package-prime-map",
            "reasoning-owner-search",
            "parser-visible-module-owner-search",
            "test-owner-search",
            "path-owner-fallback",
            "owner-item-query",
            "owner-item-code-projection",
            "owner-top-items-fallback",
            "dependency-manifest-search",
            "dependency-local-usage-search",
            "dependency-version-scope",
            "dependency-api-token-usage-search",
            "local-docs-search",
            "schema-contract-search",
            "local-semantic-schema-search",
            "exported-api-shape-search",
            "public-function-api-shape-search",
            "public-data-api-shape-search",
            "public-external-type-search",
            "public-api-type-text-search",
            "policy-rule-handle-search",
            "typescript-project-policy-rule-handle-search",
            "typescript-agent-policy-rule-handle-search",
            "typescript-extension-policy-rule-handle-search",
            "symbol-export-search",
            "owner-callsite-search",
            "import-edge-search",
            "owner-path-text-search",
            "export-text-search",
            "parser-visible-source-text-search",
            "finder-fuzzy-candidate-search",
            "parser-visible-source-fuzzy-search",
            "external-candidate-ingest",
            "stdin-shape-detection",
            "owner-grouped-ingest"
          ]
        }
      }
    },
    "ingestSurfaceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "languageId",
        "namespace",
        "name"
      ],
      "properties": {
        "languageId": {
          "const": "typescript"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "non-parser-path",
            "non-parser-text",
            "docs-text",
            "external-docs",
            "external-api-docs",
            "schema-json",
            "generated-artifact"
          ]
        }
      }
    }
  }
}
