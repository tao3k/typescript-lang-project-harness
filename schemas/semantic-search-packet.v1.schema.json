      ],
      "properties": {
        "kind": {
          "enum": [
            "owner",
            "query",
            "dependency",
            "test",
            "finding",
            "import",
            "feature",
            "custom"
          ]
        },
        "alias": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*$"
