    "reasoningProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "selectors",
        "returns"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/reasoningProfileName"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reasoningProfileSelector"
          }
        },
        "returns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          }
        },
        "frontier": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]*\\.[a-z][a-z0-9_-]*$"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "reasoningProfileSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
