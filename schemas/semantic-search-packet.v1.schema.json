        "lineRange": {
          "type": "string",
          "description": "Compact source line range as start:end, for example 10:43.",
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
        }
      }
    },
    "syntaxAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeType",
        "location"
      ],
