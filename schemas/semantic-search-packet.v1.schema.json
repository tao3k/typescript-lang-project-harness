        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "weight": {
          "type": "number"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
