{
  "schemaId": "agent.semantic-protocols.hook.provider-manifest",
  "schemaVersion": "1",
  "protocolId": "agent.semantic-protocols.hook",
  "protocolVersion": "1",
  "manifestId": "agent.semantic-protocols.providers.typescript.ts-harness",
  "manifestVersion": "v1",
  "languageId": "typescript",
  "providerId": "ts-harness",
  "namespace": "agent.semantic-protocols.languages.typescript.ts-harness",
  "binary": "ts-harness",
  "execution": "external-process",
  "source": {
    "defaultExtensions": [".ts", ".tsx", ".js", ".jsx", ".mts", ".cts", ".mjs", ".cjs"],
    "defaultConfigFiles": ["package.json", "tsconfig.json", "pnpm-workspace.yaml"],
    "defaultSourceRoots": ["src", "tests", "app", "packages"],
    "defaultIgnoredPathPrefixes": ["node_modules", "dist", "build", ".next"],
    "defaultProjectMarkers": [
      "package.json",
      "tsconfig.json",
      "jsconfig.json",
      "pnpm-workspace.yaml"
    ],
    "defaultDependencyMarkers": [
      "package.json",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "bun.lock",
      "bun.lockb"
    ]
  },
  "searchCapabilities": {
    "semanticFacts": true
  },
  "policy": {
    "directSourceRead": "block",
    "bulkSourceDump": "block",
    "rawSourceSearch": "block",
    "agentSearchJson": "block"
  },
  "routes": {
    "prime": {
      "argv": ["ts-harness", "search", "prime", "--workspace", "{projectRoot}", "--view", "seeds"]
    },
    "owner": {
      "argv": [
        "ts-harness",
        "search",
        "owner",
        "{path}",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "lexical": {
      "argv": [
        "ts-harness",
        "search",
        "lexical",
        "{query}",
        "owner",
        "tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "query": {
      "argv": [
        "ts-harness",
        "query",
        "--from-hook",
        "direct-source-read",
        "--selector",
        "{selector}",
        "{termArgs}",
        "--surface",
        "owners,tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ]
    },
    "ingest": {
      "argv": [
        "ts-harness",
        "search",
        "ingest",
        "items",
        "tests",
        "--workspace",
        "{projectRoot}",
        "--view",
        "seeds"
      ],
      "stdinMode": "pipe-candidates"
    },
    "checkChanged": {
      "argv": ["ts-harness", "check", "--changed", "{projectRoot}"]
    },
    "guide": {
      "argv": ["ts-harness", "guide", "{projectRoot}"]
    }
  }
}
