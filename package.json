{
  "name": "typescript-lang-project-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Project-level TypeScript language harness with native parser facts and compact diagnostics for agents",
  "license": "Apache-2.0",
  "bin": {
    "typescript-project-harness": "./dist/src/bin/typescript-project-harness.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/src/bin/typescript-project-harness.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "harness": "npm run build && node dist/src/bin/typescript-project-harness.js ."
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0"
  }
}
